# ── Service ──────────────────────────────────────────────────────────────────
BACKEND_PORT=
RTVI_IMAGE=

# ── NGC / NVIDIA Auth ─────────────────────────────────────────────────────────
# nvapi-* keys work as both NGC_API_KEY and NVIDIA_API_KEY
NGC_API_KEY=
NVIDIA_API_KEY=

# ── Model ─────────────────────────────────────────────────────────────────────
VLM_MODEL_TO_USE=
MODEL_PATH=

# ── GPU (RTX A4500 — 20 GB VRAM) ─────────────────────────────────────────────
NVIDIA_VISIBLE_DEVICES=
# Use 95% of VRAM (~19.4 GB). Model weights take 10.24 GiB; the rest is split
# between vision encoder cache and KV cache.
# vLLM sees 19.55 GiB total; 18.5 GiB free at startup (driver uses ~1 GiB).
# 0.93 × 19.55 =
VLLM_GPU_MEMORY_UTILIZATION=
# Conservative batch size for 20 GB card
VLM_BATCH_SIZE=
# Reduce context length: shorter KV-cache need (~1-2 GiB vs ~9 GiB for 64k).
# Alert responses are short; 8192 tokens is more than sufficient.
VLM_MAX_MODEL_LEN=
# Reduce vision encoder cache footprint: smaller resolution + fewer frames
# keeps the vision token budget well within the remaining ~9 GB.
VLM_INPUT_WIDTH=
VLM_INPUT_HEIGHT=
VLM_DEFAULT_NUM_FRAMES_PER_SECOND_OR_FIXED_FRAMES_CHUNK=

# ── RTSP ─────────────────────────────────────────────────────────────────────
# The camera uses Digest auth; skip the pre-flight media verification so
# DeepStream handles the 401 challenge natively when connecting.
VSS_SKIP_INPUT_MEDIA_VERIFICATION=
RTSP_URL=
RTSP_USER=
RTSP_PASS=

# ── Messaging ─────────────────────────────────────────────────────────────────
# Kafka disabled — alerts are delivered via SSE in monitor.py
KAFKA_ENABLED=
